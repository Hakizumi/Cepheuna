{
  "compilerOptions": {
    "rootDir": "./source",
    "outDir": "./dist",

    "module": "ES2022",
    "target": "ES2021",
    "lib": ["ES2021", "DOM"],
    "types": [],

    "sourceMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  }
}
